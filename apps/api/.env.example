# Copy to .env and fill in real values. Never commit .env.

# --- Database (see repo-root docker-compose.yml) ---
DATABASE_URL="postgresql://school:school@localhost:5432/school_erp?schema=public"

# --- Redis / BullMQ ---
REDIS_URL="redis://localhost:6379"

# --- HTTP server ---
PORT=3001

# --- Auth / JWT ---
# openssl rand -hex 32 (or similar) to generate a strong secret per environment.
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
# Refresh tokens are opaque random strings (hashed at rest in RefreshToken.tokenHash),
# not JWTs, so no signing secret is needed for them — only the rotation window.
JWT_REFRESH_EXPIRES_IN_DAYS=30

# --- Platform admin (guards platform-level routes like POST /tenants) ---
# Stopgap shared secret until real platform-admin auth exists — sent as the
# `X-Platform-Admin-Key` header. The guard fails CLOSED if this is unset, so
# it MUST be set (to a strong random value) in any shared/staging/prod env.
# openssl rand -hex 32 (or similar) to generate one.
PLATFORM_ADMIN_API_KEY="change-me-platform-admin-key"

# --- CORS ---
# Comma-separated list of allowed origins for browser clients.
CORS_ORIGINS="http://localhost:3000"

# --- Misc ---
NODE_ENV="development"
DEFAULT_TIMEZONE="Asia/Baghdad"
